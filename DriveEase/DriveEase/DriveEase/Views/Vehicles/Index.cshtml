@model IEnumerable<Models.Vehicle>

<div class="container-fluid">

    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0">🚗 Vehicle Management</h2>
            <small class="text-muted">Manage all vehicles in the system</small>
        </div>

        <a asp-action="Create" class="btn btn-primary shadow">
            + Add New Vehicle
        </a>
    </div>

    <!-- Search Box -->
    <div class="card shadow border-0 mb-4">
        <div class="card-body">
            <input type="text"
                   id="searchInput"
                   class="form-control"
                   placeholder="Search by Make or Model...">
        </div>
    </div>

    <!-- Vehicle Table -->
    <div class="card shadow border-0">
        <div class="card-body">

            <table class="table table-hover align-middle" id="vehicleTable">
                <thead class="table-light">
                    <tr>
                        <th>Make</th>
                        <th>Model</th>
                        <th>Daily Rate</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">
                                No vehicles found. Click "Add New Vehicle" to create one.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Make</td>
                                <td>@item.Model</td>
                                <td>₹@item.DailyRate</td>

                                <td>
                                    @if (item.Status == "Available")
                                    {
                                        <span class="badge rounded-pill bg-success px-3 py-2">
                                            ● Available
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill bg-danger px-3 py-2">
                                            ● Rented
                                        </span>
                                    }
                                </td>

                                <td class="text-end">
                                    <a asp-action="Edit" asp-route-id="@item.VehicleId"
                                       class="btn btn-sm btn-warning">Edit</a>

                                    <a asp-action="Details" asp-route-id="@item.VehicleId"
                                       class="btn btn-sm btn-info">Details</a>

                                    <a asp-action="Delete" asp-route-id="@item.VehicleId"
                                       class="btn btn-sm btn-danger">Delete</a>
                                </td>
                            </tr>
                        }
                      }

                </tbody>
            </table>

        </div>
    </div>

</div>

@section Scripts {
    <script>
        document.getElementById("searchInput").addEventListener("keyup", function () {
            let filter = this.value.toLowerCase();
            let rows = document.querySelectorAll("#vehicleTable tbody tr");

            rows.forEach(row => {
                let make = row.cells[0].innerText.toLowerCase();
                let model = row.cells[1].innerText.toLowerCase();

                if (make.includes(filter) || model.includes(filter)) {
                    row.style.display = "";
                } else {
                    row.style.display = "none";
                }
            });
        });
    </script>
}