@model Models.Vehicle
<div class="container mt-4">
    <div class="card shadow border-0">
        <div class="card-body">

            <h3 class="mb-4">Add New Vehicle</h3>

            <form asp-action="Create">

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label asp-for="Make" class="form-label"></label>
                        <input asp-for="Make" class="form-control" />
                        <span asp-validation-for="Make" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Model" class="form-label"></label>
                        <input asp-for="Model" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="DailyRate" class="form-label"></label>
                        <input asp-for="DailyRate" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Year" class="form-label"></label>
                        <input asp-for="Year" class="form-control" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="PassengerCapacity" class="form-label"></label>
                        <input asp-for="PassengerCapacity" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="EngineCapacity" class="form-label"></label>
                        <input asp-for="EngineCapacity" class="form-control" />
                    </div>

                </div>

                <button type="submit" class="btn btn-primary px-4 shadow">
                    Save Vehicle
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary px-4">
                    Cancel
                </a>

            </form>

        </div>
    </div>
</div>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}