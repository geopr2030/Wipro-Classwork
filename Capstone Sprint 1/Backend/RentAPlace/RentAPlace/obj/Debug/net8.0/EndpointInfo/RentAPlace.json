    "/api/Property": {
      "post": {
        "tags": [
          "Property"
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "required": [
                  "Location",
                  "PricePerNight",
                  "PropertyType",
                  "Title"
                ],
                "type": "object",
                "properties": {
                  "Title": {
                    "type": "string"
                  },
                  "Description": {
                    "type": "string"
                  },
                  "Location": {
                    "type": "string"
                  },
                  "PropertyType": {
                    "type": "string"
                  },
                  "PricePerNight": {
                    "minimum": 1,
                    "type": "number",
                    "format": "double"
                  },
                  "Features": {
                    "type": "string"
                  },
                  "images": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "format": "binary"
                    }
                  }
                }
              },
              "encoding": {
                "Title": {
                  "style": "form"
                },
                "Description": {
                  "style": "form"
                },
                "Location": {
                  "style": "form"
                },
                "PropertyType": {
                  "style": "form"
                },
                "PricePerNight": {
                  "style": "form"
                },
                "Features": {
                  "style": "form"
                },
                "images": {
                  "style": "form"
                }
              }
            }
          }
        },
        "responses": {
